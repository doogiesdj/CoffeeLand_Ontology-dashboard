  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- producedFor / sourcedFrom  ObjectProperty 선언            -->
  <!-- ══════════════════════════════════════════════════════════ -->

  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#producedFor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Farm"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeBrand"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#sourcedFrom"/>
    <rdfs:label xml:lang="ko">원두 공급 대상 브랜드</rdfs:label>
    <rdfs:label xml:lang="en">produced for</rdfs:label>
    <rdfs:comment xml:lang="ko">농장(Farm)이 원두를 공급하는 커피 브랜드. 역방향은 sourcedFrom.</rdfs:comment>
  </rdf:Description>

  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#sourcedFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeBrand"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Farm"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#producedFor"/>
    <rdfs:label xml:lang="ko">원두 공급 농장</rdfs:label>
    <rdfs:label xml:lang="en">sourced from</rdfs:label>
    <rdfs:comment xml:lang="ko">커피 브랜드의 원두를 공급하는 농장. producedFor의 역방향.</rdfs:comment>
  </rdf:Description>



  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- 관계2~5 ObjectProperty 선언 (자동 병합)                    -->
