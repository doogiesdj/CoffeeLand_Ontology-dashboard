    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeChain"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#offersMenu"/>
    <rdfs:label xml:lang="ko">제공 체인</rdfs:label>
    <rdfs:label xml:lang="en">offered by</rdfs:label>
    <rdfs:comment xml:lang="ko">음료 메뉴를 제공하는 커피체인. offersMenu의 역방향.</rdfs:comment>
  </rdf:Description>
  <!-- ObjectProperty: containsIngredient -->
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#containsIngredient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
