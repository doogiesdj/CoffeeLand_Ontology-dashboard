    <owl:inverseOf rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#offeredBy"/>
    <rdfs:label xml:lang="ko">제공 메뉴</rdfs:label>
    <rdfs:label xml:lang="en">offers menu</rdfs:label>
    <rdfs:comment xml:lang="ko">커피체인이 제공하는 음료 메뉴.</rdfs:comment>
  </rdf:Description>
  <!-- ObjectProperty: offeredBy -->
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#offeredBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
