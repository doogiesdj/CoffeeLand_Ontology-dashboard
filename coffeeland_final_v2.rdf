    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Ingredient"/>
    <rdfs:label xml:lang="ko">얼음</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Ing_NitrogenGas">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Ingredient"/>
    <rdfs:label xml:lang="ko">질소 가스</rdfs:label>
  </rdf:Description>


  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- 18개 심층 관계 추가 (OWL 공리·공급사슬·인증·시장·품질추적성)        -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Farm">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#cultivates"/>
        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeVariety"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#isLocatedIn"/>
        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Country"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#BeverageMenu">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#containsIngredient"/>
        <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Ingredient"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#suppliedToChain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:propertyChainAxiom rdf:parseType="Collection">
      <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#producedFor"/>
      <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#mediates"/>
    </owl:propertyChainAxiom>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Farm"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeBrand"/>
    <rdfs:label xml:lang="ko">공급 체인 연결 (추론)</rdfs:label>
    <rdfs:label xml:lang="en">supplied to chain</rdfs:label>
    <rdfs:comment xml:lang="ko">Farm → producedFor → CoffeeBrand → mediates → CoffeeChain 경로를 자동 추론합니다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Farm">
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeChain"/>
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Broker"/>
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Warehouse"/>
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Port"/>
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#BeverageMenu"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeChain">
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Farm"/>
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Broker"/>
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Port"/>
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Warehouse"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#ExportBroker">
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#ImportBroker"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Port">
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Warehouse"/>
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Farm"/>
    <owl:disjointWith rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeChain"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#usesByChain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeBrand"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeChain"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#sourcesBrandFrom"/>
    <rdfs:label xml:lang="ko">공급 커피체인</rdfs:label>
    <rdfs:label xml:lang="en">uses by chain</rdfs:label>
    <rdfs:comment xml:lang='ko'>CoffeeBrand를 사용하는 CoffeeChain.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#sourcesBrandFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeChain"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeBrand"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#usesByChain"/>
    <rdfs:label xml:lang="ko">소싱 브랜드</rdfs:label>
    <rdfs:label xml:lang="en">sources brand from</rdfs:label>
    <rdfs:comment xml:lang='ko'>CoffeeChain이 소싱하는 CoffeeBrand. usesByChain의 역방향.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#memberOfCoop">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Farm"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Cooperative"/>
    <rdfs:label xml:lang="ko">협동조합 소속</rdfs:label>
    <rdfs:label xml:lang="en">member of cooperative</rdfs:label>
    <rdfs:comment xml:lang='ko'>농장이 가입한 협동조합.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#hasMemberFarm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Cooperative"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Farm"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#memberOfCoop"/>
    <rdfs:label xml:lang="ko">소속 농장</rdfs:label>
    <rdfs:label xml:lang="en">has member farm</rdfs:label>
    <rdfs:comment xml:lang='ko'>협동조합에 소속된 농장. memberOfCoop의 역방향.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#transportsFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#LogisticsProvider"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Port"/>
    <rdfs:label xml:lang="ko">출발 항구</rdfs:label>
    <rdfs:label xml:lang="en">transports from</rdfs:label>
    <rdfs:comment xml:lang='ko'>물류 제공자의 원두 출발 항구.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#transportsTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#LogisticsProvider"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Port"/>
    <rdfs:label xml:lang="ko">도착 항구</rdfs:label>
    <rdfs:label xml:lang="en">transports to</rdfs:label>
    <rdfs:comment xml:lang='ko'>물류 제공자의 원두 도착 항구.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#usesWarehouse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#LogisticsProvider"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Warehouse"/>
    <rdfs:label xml:lang="ko">사용 창고</rdfs:label>
    <rdfs:label xml:lang="en">uses warehouse</rdfs:label>
    <rdfs:comment xml:lang='ko'>물류 제공자가 운영/사용하는 창고.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#operatesWarehouse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeChain"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Warehouse"/>
    <rdfs:label xml:lang="ko">운영 창고</rdfs:label>
    <rdfs:label xml:lang="en">operates warehouse</rdfs:label>
    <rdfs:comment xml:lang='ko'>커피체인이 직접 운영하는 창고.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CertificationBody">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Organization"/>
    <rdfs:label xml:lang="ko">인증 기관</rdfs:label>
    <rdfs:label xml:lang="en">Certification Body</rdfs:label>
    <rdfs:comment xml:lang='ko'>커피 인증을 발급하는 국제 기관.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#issuedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Certification"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CertificationBody"/>
    <rdfs:label xml:lang="ko">발급 기관</rdfs:label>
    <rdfs:label xml:lang="en">issued by</rdfs:label>
    <rdfs:comment xml:lang='ko'>인증을 발급한 기관.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#issuesCertification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CertificationBody"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Certification"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#issuedBy"/>
    <rdfs:label xml:lang="ko">발급 인증</rdfs:label>
    <rdfs:label xml:lang="en">issues certification</rdfs:label>
    <rdfs:comment xml:lang='ko'>기관이 발급하는 인증. issuedBy의 역방향.</rdfs:comment>
  </rdf:Description>  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Fairtrade_International">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CertificationBody"/>
    <rdfs:label xml:lang="ko">Fairtrade International</rdfs:label>
    <cof:issuesCertification rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Fair_Trade"/>
  </rdf:Description>  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Rainforest_Alliance_Org">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CertificationBody"/>
    <rdfs:label xml:lang="ko">Rainforest Alliance Org</rdfs:label>
    <cof:issuesCertification rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Rainforest_Alliance"/>
  </rdf:Description>  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#USDA_Organic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CertificationBody"/>
    <rdfs:label xml:lang="ko">USDA Organic</rdfs:label>
    <cof:issuesCertification rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Organic"/>
  </rdf:Description>  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#UTZ_Certified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CertificationBody"/>
    <rdfs:label xml:lang="ko">UTZ Certified</rdfs:label>
    <cof:issuesCertification rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#UTZ"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#brandHasCertification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeBrand"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Certification"/>
    <rdfs:label xml:lang="ko">브랜드 인증</rdfs:label>
    <rdfs:label xml:lang="en">brand has certification</rdfs:label>
    <rdfs:comment xml:lang='ko'>커피 브랜드가 보유한 인증. 농장 인증에서 파생.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#SustainabilityMetric">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>

    <rdfs:label xml:lang="ko">지속가능성 지표</rdfs:label>
    <rdfs:label xml:lang="en">Sustainability Metric</rdfs:label>
    <rdfs:comment xml:lang='ko'>커피 생산의 환경·사회적 영향 지표.</rdfs:comment>
      <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Sustainability"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#hasImpact">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Farm"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#SustainabilityMetric"/>
    <rdfs:label xml:lang="ko">지속가능성 영향</rdfs:label>
    <rdfs:label xml:lang="en">has impact</rdfs:label>
    <rdfs:comment xml:lang='ko'>농장의 환경·사회적 영향 지표.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#hasBrandImpact">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#CoffeeBrand"/>
    <rdfs:range  rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#SustainabilityMetric"/>
    <rdfs:label xml:lang="ko">브랜드 지속가능성 영향</rdfs:label>
    <rdfs:label xml:lang="en">has brand impact</rdfs:label>
    <rdfs:comment xml:lang='ko'>브랜드 레벨의 지속가능성 지표.</rdfs:comment>
  </rdf:Description>  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Metric_CO2_Low">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#SustainabilityMetric"/>
    <rdfs:label xml:lang="ko">저탄소 생산 (1kg당 CO2 3kg 이하)</rdfs:label>
  </rdf:Description>  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Metric_CO2_High">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#SustainabilityMetric"/>
    <rdfs:label xml:lang="ko">고탄소 생산 (1kg당 CO2 6kg 초과)</rdfs:label>
  </rdf:Description>  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Metric_Water_Efficient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#SustainabilityMetric"/>
    <rdfs:label xml:lang="ko">효율적 수자원 사용 (1kg당 140L 이하)</rdfs:label>
  </rdf:Description>  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Metric_Water_Heavy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#SustainabilityMetric"/>
    <rdfs:label xml:lang="ko">집약적 수자원 사용 (1kg당 200L 초과)</rdfs:label>
