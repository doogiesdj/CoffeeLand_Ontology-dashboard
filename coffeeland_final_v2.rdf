    <rdfs:comment xml:lang='ko'>음료 메뉴에 사용되는 커피 원두 브랜드. 메뉴→농장 추론 체인의 핵심 연결.</rdfs:comment>
  </rdf:Description>


  <!-- Certification 인스턴스 -->
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Fair_Trade">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Certification"/>
    <cof:issuedBy rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Fairtrade_International"/>
    <rdfs:label xml:lang="ko">공정무역 인증</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Rainforest_Alliance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Certification"/>
    <cof:issuedBy rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Rainforest_Alliance_Org"/>
    <rdfs:label xml:lang="ko">레인포레스트 얼라이언스 인증</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Organic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Certification"/>
    <cof:issuedBy rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#USDA_Organic"/>
    <rdfs:label xml:lang="ko">유기농 인증</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#UTZ">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Certification"/>
    <cof:issuedBy rdf:resource="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#UTZ_Certified"/>
    <rdfs:label xml:lang="ko">UTZ 지속가능 농업 인증</rdfs:label>
  </rdf:Description>



  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#isLocatedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
  </rdf:Description>


  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#AgriEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">농업 활동 이벤트</rdfs:label>
    <rdfs:label xml:lang="en">Agricultural Event</rdfs:label>
    <rdfs:comment xml:lang="en">Time-based agricultural activities occurring at a farm, such as harvesting, planting, and processing. Serves as the parent class for all farm-level operational events in the Coffeeland supply chain.</rdfs:comment>
  </rdf:Description>

  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#Sustainability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">지속가능성 평가 체계</rdfs:label>
    <rdfs:label xml:lang="en">Sustainability</rdfs:label>
    <rdfs:comment xml:lang="en">ESG (Environmental, Social, Governance) concepts including metrics, indicators, and criteria used to evaluate the environmental and social impact of coffee production and trade.</rdfs:comment>
  </rdf:Description>

  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#adjacentTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:label xml:lang="ko">인접</rdfs:label>
    <rdfs:label xml:lang="en">adjacent to</rdfs:label>
    <rdfs:comment xml:lang="en">Connects a Warehouse to a nearby Port. Declared Symmetric so adjacency is automatically inferred in both directions. No domain or range restriction to avoid contradiction with Port DisjointWith Warehouse.</rdfs:comment>
  </rdf:Description>

</rdf:RDF>
