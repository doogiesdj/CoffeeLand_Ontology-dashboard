  </rdf:Description>
  <!-- ObjectProperty: adjacentTo -->
  <!-- ObjectProperty: purchasesFrom -->
  <rdf:Description rdf:about="http://www.semanticweb.org/boogi/ontologies/2025/11/untitled-ontology-2#purchasesFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
